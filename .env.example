# Groq API key — free at https://console.groq.com/keys
# WITHOUT a key the whole system runs on a deterministic offline mock
# (great for demos and the test suite). WITH a key the agents use a real LLM.
GROQ_API_KEY=

# Force the deterministic offline mock even if a key is present (1/0).
# The comparison mode uses this so runs are reproducible.
ATLAS_FORCE_MOCK=0

# Optional model override.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional runtime knobs (defaults shown).
ATLAS_RUNTIME=pooled
ATLAS_MAX_HEADCOUNT=12
ATLAS_MAX_DEPTH=3
ATLAS_TOKEN_BUDGET=150000
