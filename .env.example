# Groq API key — REQUIRED. This build uses a real LLM only (no offline mock).
# Get one free at https://console.groq.com/keys
GROQ_API_KEY=

# Optional model override.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional runtime knobs (defaults shown).
ATLAS_RUNTIME=pooled
ATLAS_MAX_HEADCOUNT=12
ATLAS_MAX_DEPTH=3
ATLAS_TOKEN_BUDGET=150000
