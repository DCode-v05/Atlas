# ─── Atlas configuration ──────────────────────────────────────────────────────
# Copy to `.env` and edit. All ATLAS_* vars are optional (sensible defaults).

ATLAS_SEED=42

# Cron simulation (kept gentle so the LLM isn't hammered).
# ATLAS_CRON_LOOP=false → a single ~15s burst that auto-stops (the default).
# ATLAS_CRON_LOOP=true  → continuous: a goal every ATLAS_CRON_GOAL_SECONDS until off.
ATLAS_CRON_LOOP=false
ATLAS_CRON_BURST_SECONDS=15
ATLAS_CRON_GOAL_SECONDS=30
ATLAS_CRON_TICK_SECONDS=1.0
ATLAS_HITL_TIMEOUT_SECONDS=0

# Edge authentication (opt-in). Unset = the /api edge is open (default).
# Set it and every /api/* call (except /api/healthz) must present the key via the
# X-API-Key header, an Authorization: Bearer token, or ?key= (used by the SSE
# stream, since EventSource can't send headers). The bundled UI is served the key
# inline so it keeps working — front Atlas with a real auth proxy to harden it.
# ATLAS_API_KEY=

# Persistence + authenticated network (opt-in). Set a Postgres URL to enable the DB-backed mode
# (org mirrored to DB, runtime + auth/session state persisted, agents authenticate to JOIN the
# network). Unset = fully in-memory. docker-compose wires this automatically to the bundled DB.
# ATLAS_DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas

ATLAS_HOST=0.0.0.0
ATLAS_PORT=8000

# ═══ Amazon Bedrock (Mistral) — REQUIRED ══════════════════════════════════════
# Atlas runs real Mistral via Amazon Bedrock on every path (user prompts AND the
# cron simulation). There is NO simulated fallback: without credentials the app
# refuses to start. Pick ONE auth option below (A or B).
#
# Also required on the AWS side, or every call fails (you'll see it in the logs):
#   1. Enable model access:  AWS Console → Bedrock → Model access → enable Mistral.
#   2. The principal needs the  bedrock:InvokeModel  permission.
#   3. AWS_REGION must be where you enabled Bedrock + that model.

AWS_REGION=us-east-1

# ── Option A — classic IAM access key + secret (most common) ──────────────────
# This is the AccessKeyId / SecretAccessKey pair from an IAM user.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=          # only for temporary (STS) credentials

# ── Option B — a Bedrock API key (bearer token) INSTEAD of A ──────────────────
# NOTE: this is NOT an access-key id. Generate it in AWS Console → Bedrock →
# API keys → Generate. It has a special prefix. If you use B, leave A blank.
# AWS_BEARER_TOKEN_BEDROCK=

# ── Mistral model ids (override if you've enabled different ones) ─────────────
# ATLAS_BEDROCK_REASONING_MODEL=mistral.mistral-large-2402-v1:0
# ATLAS_BEDROCK_PHRASING_MODEL=mistral.mistral-large-2402-v1:0

# ── Throttling (raise on a paid / higher-quota account) ──────────────────────
# ATLAS_BEDROCK_RPM=22
# ATLAS_BEDROCK_BURST=5
