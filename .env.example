# ─── Atlas configuration ──────────────────────────────────────────────────────
# Copy to `.env` and edit. All ATLAS_* vars are optional (sensible defaults).

# Deterministic seed — drives org generation and the (seeded) cron sequence.
ATLAS_SEED=42

# Cron simulation burst length (seconds) and tick cadence.
ATLAS_CRON_BURST_SECONDS=15
ATLAS_CRON_TICK_SECONDS=0.8
ATLAS_CRON_LOOP=false

# HITL auto-decision timeout in seconds (0 = wait forever for the operator).
ATLAS_HITL_TIMEOUT_SECONDS=0

# Server bind.
ATLAS_HOST=0.0.0.0
ATLAS_PORT=8000

# ─── Groq (REQUIRED) ──────────────────────────────────────────────────────────
# Atlas runs real Groq agents on every path — user prompts AND the cron
# simulation. There is NO simulated fallback: without this key the app refuses
# to start. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional model overrides:
# ATLAS_GROQ_REASONING_MODEL=llama-3.3-70b-versatile
# ATLAS_GROQ_PHRASING_MODEL=llama-3.1-8b-instant
